{
  "name": "freestyle",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "workers/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --prefix apps/web run dev",
    "dev:turbo": "npm --prefix apps/web run dev:turbo",
    "dev:all": "node scripts/dev-all.mjs",
    "dev:api": "tsx apps/api/src/main.ts",
    "dev:worker:importer": "tsx workers/importer/src/worker.ts",
    "dev:worker:bg2": "tsx workers/background_removal/src/worker.ts",
    "dev:worker:background-removal": "tsx workers/background_removal/src/worker.ts",
    "dev:worker:asset": "tsx workers/asset_processor/src/worker.ts",
    "dev:worker:evaluator": "tsx workers/evaluator/src/worker.ts",
    "dev:worker:tryon2": "tsx workers/tryon/src/worker.ts",
    "dev:worker:tryon": "tsx workers/tryon/src/worker.ts",
    "serve:api": "tsx apps/api/src/main.ts",
    "serve:worker:importer": "tsx workers/importer/src/worker.ts",
    "serve:worker:background-removal": "tsx workers/background_removal/src/worker.ts",
    "serve:worker:asset-processor": "tsx workers/asset_processor/src/worker.ts",
    "serve:worker:evaluator": "tsx workers/evaluator/src/worker.ts",
    "serve:worker:tryon": "tsx workers/tryon/src/worker.ts",
    "build:services": "tsc -p tsconfig.monorepo.json",
    "start:api": "node dist/apps/api/src/main.js",
    "start:worker:importer": "node dist/workers/importer/src/worker.js",
    "start:worker:background-removal": "node dist/workers/background_removal/src/worker.js",
    "start:worker:asset-processor": "node dist/workers/asset_processor/src/worker.js",
    "start:worker:evaluator": "node dist/workers/evaluator/src/worker.js",
    "start:worker:tryon": "node dist/workers/tryon/src/worker.js",
    "build": "npm --prefix apps/web run build",
    "check": "npm run lint && npm run typecheck && npm run build:services && npm run build",
    "start": "npm --prefix apps/web run start",
    "lint": "eslint",
    "typecheck": "npm --prefix apps/web run typecheck"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.921.0",
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/sensible": "^6.0.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.91.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fastify": "^5.6.2",
    "framer-motion": "^12.29.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
