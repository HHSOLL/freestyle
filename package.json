{
  "name": "fsp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "dev:all": "node scripts/dev-all.mjs",
    "build": "next build --webpack",
    "check": "npm run lint && npm run typecheck && npm run build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "smoke:human-signals": "ts-node --project tsconfig.worker.json --transpile-only scripts/human-signal-smoke.ts",
    "worker:bg": "ts-node -r tsconfig-paths/register --project tsconfig.worker.json --transpile-only src/worker/bgRemovalWorker.ts",
    "worker:import": "ts-node -r tsconfig-paths/register --project tsconfig.worker.json --transpile-only src/worker/importWorker.ts",
    "worker:vto": "ts-node -r tsconfig-paths/register --project tsconfig.worker.json --transpile-only src/worker/vtoWorker.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.91.1",
    "@tensorflow-models/blazeface": "^0.1.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "bullmq": "^5.40.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.29.0",
    "ioredis": "^5.5.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
