# ------------------------------
# Deployment topology
# Vercel (frontend) -> Railway (API) -> Supabase
# ------------------------------

# Set on Vercel frontend to proxy /api/* to Railway backend.
# Example: https://freestyle-api.up.railway.app
BACKEND_ORIGIN=

# Optional for direct browser calls (usually keep empty when BACKEND_ORIGIN is used).
# Example: https://freestyle-api.up.railway.app
NEXT_PUBLIC_API_BASE_URL=

# ------------------------------
# Core runtime
# ------------------------------

NODE_ENV=development
ALLOWED_IMAGE_HOSTS=
# Explicit browser origins are required when requests include an `Origin` header.
# Leave empty only for same-origin proxy setups such as Vercel -> `/api/*` -> Railway.
CORS_ORIGIN=
CORS_ORIGIN_PATTERNS=
API_PUBLIC_ORIGIN=

# ------------------------------
# Supabase
# ------------------------------

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_AUTH_KAKAO_ENABLED=false
NEXT_PUBLIC_AUTH_NAVER_ENABLED=false
NEXT_PUBLIC_AUTH_REQUIRED=false
SUPABASE_STORAGE_BUCKET=freestyle-assets
# Explicit opt-in only. Product anonymous flows should prefer browser auth/session state.
ALLOW_ANONYMOUS_USER=false

# ------------------------------
# Storage provider
# ------------------------------

STORAGE_PROVIDER=supabase
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# ------------------------------
# AI providers
# ------------------------------

REMOVE_BG_API_KEY=
BG_REMOVAL_API_KEY=
BG_REMOVAL_ENDPOINT=
GEMINI_API_KEY=
GEMINI_REVIEW_MODEL=gemini-3.1-flash-lite-preview
VTO_ENDPOINT=
VTO_API_KEY=
VTO_AUTH_HEADER=Authorization
VTO_AUTH_SCHEME=Bearer
EVALUATOR_MODEL=gemini-3.1-flash-lite-preview
TRYON_MODEL=gemini-3.1-flash-image-preview
EMBEDDING_MODEL=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_STATE_SECRET=

# ------------------------------
# Import / worker tuning
# ------------------------------

BG_REMOVAL_CONCURRENCY=2
VTO_CONCURRENCY=1
IMPORT_CONCURRENCY=2
IMPORT_CART_ITEM_CONCURRENCY=3
STRICT_NO_MODEL_IMPORT=false
WORKER_POLL_INTERVAL_MS=750
WORKER_CLAIM_BATCH=10
WORKER_HEARTBEAT_SEC=10
WORKER_STALE_JOB_MINUTES=5
WORKER_JOB_TYPES=all

# ------------------------------
# Storage paths (local fallback)
# ------------------------------

ASSET_STORAGE_PATH=./data/assets
ASSET_INDEX_PATH=
OUTFITS_STORAGE_PATH=./data/outfits.json
ALLOW_FILESYSTEM_STORAGE_IN_PRODUCTION=false
